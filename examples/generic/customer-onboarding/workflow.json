            },
            {
              "id": "email-4",
              "name": "status",
              "value": "sent",
              "type": "string"
            },
            {
              "id": "email-5",
              "name": "customer_name",
              "value": "={{ $json.body.customer_name }}",
              "type": "string"
            },
            {
              "id": "email-6",
              "name": "customer_email",
              "value": "={{ $json.body.customer_email }}",
              "type": "string"
            },
            {
              "id": "email-7",
              "name": "plan_type",
              "value": "={{ $json.body.plan_type }}",
              "type": "string"
            },
            {
              "id": "email-8",
              "name": "company_name",
              "value": "={{ $json.body.company_name }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000002",
      "name": "Send Welcome Email",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        460,
        300
