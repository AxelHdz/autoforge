              "id": "slack-1",
              "name": "slack_channel",
              "value": "#account-management",
              "type": "string"
            },
            {
              "id": "slack-2",
              "name": "slack_message",
              "value": "=New enterprise customer signed up! {{ $json.customer_name }} from {{ $json.company_name }} ({{ $json.customer_email }}). Plan: {{ $json.plan_type }}. Please reach out to schedule a kickoff call.",
              "type": "string"
            },
            {
              "id": "slack-3",
              "name": "status",
