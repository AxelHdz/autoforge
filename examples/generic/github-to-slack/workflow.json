              "type": "string"
            },
            {
              "id": "assign-ignore-3",
              "name": "label_received",
              "value": "={{ $json.body.label.name }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000004",
      "name": "Ignore Event",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [680, 400]
    }
