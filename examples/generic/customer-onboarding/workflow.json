{
  "name": "Customer Onboarding Pipeline",
  "nodes": [
    {
      "parameters": {
        "path": "customer-onboarding",
        "httpMethod": "POST",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
